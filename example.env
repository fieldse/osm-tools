# OSM CLI environment configuration
# Copy to .env and fill in your values.

# Your OpenSourceMalware.com API token (starts with "osm_").
# Get one at https://opensourcemalware.com → Settings → API Tokens.
OSM_API_KEY=osm_your_token_here

# Optional: override the API base URL (for testing/staging).
# Defaults to https://api.opensourcemalware.com/v1 when unset.
OSM_BASE_URL=
